$C = "../Common.ui";

SceneBlur {}

Group {
  Background: #000000(0.34);
}

Group {
  Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
  LayoutMode: Center;

  Group {
    Anchor: (Width: 1280, Height: 780);

    // ─────────────────────────────────────────────────────────────────────────
    //  TOP BAR
    // ─────────────────────────────────────────────────────────────────────────
    Group #TopBar {
      Anchor: (Left: 24, Top: 18, Right: 24, Height: 66);
      Background: PatchStyle(TexturePath: "ObjectivePanelContainer.png", Border: 15);

      Label #Title {
        Anchor: (Left: 18, Top: 18, Width: 330, Height: 30);
        Style: (FontSize: 20, TextColor: #e0c27a, RenderBold: true, VerticalAlignment: Center);
        Text: "Mob Marker Filters";
      }

      Group {
        Anchor: (Left: 350, Top: 14, Right: 254, Height: 38);
        Background: PatchStyle(TexturePath: "InputBox.png", Border: 16);
        OutlineColor: #5d6778;
        OutlineSize: 1;
        Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);

        TextField #SearchInput {
          Anchor: (Full: 0);
          PlaceholderText: "Type a mob name or role key";
          PlaceholderStyle: $C.@DefaultInputFieldPlaceholderStyle;
        }
      }

      Button #ClearSearchButton {
        Anchor: (Top: 14, Right: 86, Width: 148, Height: 38);
        Background: #343850;
        OutlineColor: #c7b37b;
        OutlineSize: 1;
        Label #ClearSearchButtonLabel {
          Anchor: (Full: 0);
          Text: "Clear";
          Style: (FontSize: 14, TextColor: #f1f7fa, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        }
      }

      Label #ResultsSummary {
        Anchor: (Left: 350, Top: 52, Right: 254, Height: 10);
        Style: (FontSize: 10, TextColor: #8f98aa, HorizontalAlignment: Center);
        Text: "Showing 0 mob types";
        Visible: false;
      }

      Button #CloseButton {
        Anchor: (Top: 17, Right: 24, Width: 32, Height: 32);
        Style: (
          Default: (Background: "ContainerCloseButton.png"),
          Hovered: (Background: "ContainerCloseButtonHovered.png"),
          Pressed: (Background: "ContainerCloseButtonPressed.png")
        );
        Label #CloseButtonLabel {
          Anchor: (Full: 0);
          Text: "X";
          Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
          Visible: false;
        }
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    //  SIDEBAR
    // ─────────────────────────────────────────────────────────────────────────
    Group #Sidebar {
      Anchor: (Left: 24, Top: 110, Width: 266, Bottom: 24);
      Background: PatchStyle(TexturePath: "ObjectivePanelContainer.png", Border: 15);

      Label {
        Anchor: (Left: 16, Top: 16, Right: 16, Height: 13);
        Style: (FontSize: 10, TextColor: #cdbb8d, RenderBold: true, LetterSpacing: 1);
        Text: "VISIBILITY STATUS";
      }

      // Map status box
      Group #MapStatusBox {
        Anchor: (Left: 12, Top: 37, Right: 12, Height: 56);
        Background: #192131;
        OutlineColor: #505f78;
        OutlineSize: 1;
        Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8);

        Group #MapStatusDot {
          Anchor: (Left: 0, Top: 6, Width: 10, Height: 10);
          Background: #246a49;
        }

        Label #MapStatusLabel {
          Anchor: (Left: 18, Top: 0, Right: 0, Height: 20);
          Style: (FontSize: 13, TextColor: #e6ebf4, RenderBold: true, VerticalAlignment: Center);
          Text: "Map";
        }

        Label #MapStatusCount {
          Anchor: (Left: 18, Top: 24, Right: 0, Height: 14);
          Style: (FontSize: 11, TextColor: #8f96ab, VerticalAlignment: Center);
          Text: "0/0 on";
        }
      }

      // Minimap status box
      Group #MinimapStatusBox {
        Anchor: (Left: 12, Top: 101, Right: 12, Height: 56);
        Background: #192131;
        OutlineColor: #505f78;
        OutlineSize: 1;
        Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8);

        Group #MinimapStatusDot {
          Anchor: (Left: 0, Top: 6, Width: 10, Height: 10);
          Background: #246a49;
        }

        Label #MinimapStatusLabel {
          Anchor: (Left: 18, Top: 0, Right: 0, Height: 20);
          Style: (FontSize: 13, TextColor: #e6ebf4, RenderBold: true, VerticalAlignment: Center);
          Text: "Minimap";
        }

        Label #MinimapStatusCount {
          Anchor: (Left: 18, Top: 24, Right: 0, Height: 14);
          Style: (FontSize: 11, TextColor: #8f96ab, VerticalAlignment: Center);
          Text: "0/0 on";
        }
      }

      // Compass status box
      Group #CompassStatusBox {
        Anchor: (Left: 12, Top: 165, Right: 12, Height: 56);
        Background: #192131;
        OutlineColor: #505f78;
        OutlineSize: 1;
        Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8);

        Group #CompassStatusDot {
          Anchor: (Left: 0, Top: 6, Width: 10, Height: 10);
          Background: #246a49;
        }

        Label #CompassStatusLabel {
          Anchor: (Left: 18, Top: 0, Right: 0, Height: 20);
          Style: (FontSize: 13, TextColor: #e6ebf4, RenderBold: true, VerticalAlignment: Center);
          Text: "Compass";
        }

        Label #CompassStatusCount {
          Anchor: (Left: 18, Top: 24, Right: 0, Height: 14);
          Style: (FontSize: 11, TextColor: #8f96ab, VerticalAlignment: Center);
          Text: "0/0 on";
        }
      }

      // Separator
      Group {
        Anchor: (Left: 12, Top: 233, Right: 12, Height: 1);
        Background: #4e5a6f;
      }

      Label {
        Anchor: (Left: 16, Top: 248, Right: 16, Height: 13);
        Style: (FontSize: 10, TextColor: #cdbb8d, RenderBold: true, LetterSpacing: 1);
        Text: "BULK TOGGLE";
      }

      Button #MapBulkButton {
        Anchor: (Left: 12, Top: 270, Right: 12, Height: 48);
        Background: #66582e;
        OutlineColor: #c7b37b;
        OutlineSize: 1;
        Label #MapBulkButtonLabel {
          Anchor: (Full: 0);
          Text: "Map";
          Style: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        }
      }

      Button #MinimapBulkButton {
        Anchor: (Left: 12, Top: 326, Right: 12, Height: 48);
        Background: #66582e;
        OutlineColor: #c7b37b;
        OutlineSize: 1;
        Label #MinimapBulkButtonLabel {
          Anchor: (Full: 0);
          Text: "Minimap";
          Style: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        }
      }

      Button #CompassBulkButton {
        Anchor: (Left: 12, Top: 382, Right: 12, Height: 48);
        Background: #66582e;
        OutlineColor: #c7b37b;
        OutlineSize: 1;
        Label #CompassBulkButtonLabel {
          Anchor: (Full: 0);
          Text: "Compass";
          Style: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        }
      }
    }

    // ─────────────────────────────────────────────────────────────────────────
    //  MAIN PANEL
    // ─────────────────────────────────────────────────────────────────────────
    Group #MainPanel {
      Anchor: (Left: 316, Top: 110, Right: 24, Bottom: 24);
      Background: #000000(0.0);

      Group #HeaderRow {
        Anchor: (Left: 0, Top: 0, Right: 0, Height: 42);
        Background: #1a2232;
        OutlineColor: #566278;
        OutlineSize: 1;
        Visible: false;

        Label #ColumnName {
          Anchor: (Left: 104, Top: 12, Width: 200, Height: 18);
          Style: (FontSize: 13, TextColor: #e7edf7, RenderBold: true, VerticalAlignment: Center);
          Text: "Mob";
        }

        Label #ColumnMap {
          Anchor: (Top: 12, Right: 362, Width: 120, Height: 18);
          Style: (FontSize: 13, TextColor: #d3dbe8, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "Map";
        }

        Label #ColumnMinimap {
          Anchor: (Top: 12, Right: 236, Width: 120, Height: 18);
          Style: (FontSize: 13, TextColor: #d3dbe8, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "Minimap";
        }

        Label #ColumnCompass {
          Anchor: (Top: 12, Right: 110, Width: 120, Height: 18);
          Style: (FontSize: 13, TextColor: #d3dbe8, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "Compass";
        }
      }

      Group #RowsCard {
        Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
        Background: PatchStyle(TexturePath: "ObjectivePanelContainer.png", Border: 15);
        OutlineColor: #566278;
        OutlineSize: 1;
        Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10);

        Group #RowsScroll {
          Anchor: (Full: 0);
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;

          Group #RowGroup {
            LayoutMode: Top;
          }
        }

        Label #EmptyState {
          Anchor: (Top: 22, Left: 16, Right: 16, Height: 22);
          Style: (FontSize: 13, TextColor: #8f96ab, HorizontalAlignment: Center);
          Text: "No mob types match the current search yet.";
          Visible: false;
        }

        Label #LoadingState {
          Anchor: (Top: 22, Left: 16, Right: 16, Height: 22);
          Style: (FontSize: 13, TextColor: #cdbb8d, HorizontalAlignment: Center, RenderBold: true);
          Text: "Loading full mob catalog...";
          Visible: false;
        }
      }
    }

  }
}